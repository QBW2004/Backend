<?xml version="1.0" encoding="utf-8"?>

<log4net>
  <appender name="RollingFileAppender" type="log4net.Appender.RollingFileAppender">
    <File value="Logs\" />
    <PreserveLogFileNameExtension value="true" />
    <!--是否追加到文件-->
    <appendToFile value="false" />
    <!-- RollingStyle Composite 综合  Size 按大小  Date 按时间 -->
    <param name="RollingStyle" value="Composite" />
    <!--日期的格式-->
    <datePattern value="'yyt_'yyyyMMdd'.log'" />
    <!--最大变换数量-->
    <maxSizeRollBackups value="1000" />
    <!--最大文件大小-->
    <maximumFileSize value="5MB" />
    <!--是否只写到一个文件中-->
    <staticLogFileName value="false" />
    <!--输出格式-->
    <layout type="log4net.Layout.PatternLayout">
      <!--样例：2008-03-26 13:42:32,111 [10] INFO  Log4NetDemo.MainClass [(null)] - info-->
      <!--<conversionPattern value="%n%n记录时间：〖%date〗%n  线程ID：〖%thread〗 %n  记录类：%logger %n记录位置：%location %n描述信息：%message %n%n" />-->
      <!--<conversionPattern value="%n%n记录时间：〖%date〗%n记录位置：%location %n描述信息：%n%message " />-->
      <conversionPattern value="%n记录时间：〖%date〗%n描述信息：%message %n" />
    </layout>
  </appender>
  <root>
    <!--RollingFileAppender事件日志-->
    <appender-ref ref="RollingFileAppender" />
  </root>
</log4net>
  
