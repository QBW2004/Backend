    <link href="@Url.Content("~/Scripts/plugins/toastr/toastr.min.css")" rel="stylesheet" />
    <script src="@Url.Content("~/Scripts/plugins/toastr/toastr.min.js")"></script>
    <script src="@Url.Content("~/Scripts/jquery.signalR-2.4.1.min.js")"></script>

    <script src="@Url.Content("~/signalr/hubs")"></script>
    <script>
        toastr.options.timeOut = 3000;
        toastr.options.extendedTimeOut = 1000;
        toastr.options.onShown = function () {
        }
        toastr.options.onHidden = function () {
            stopSound();// 关闭声音提示
        }
        function showTip(_msg) {
            playSound();
            toastr.info(_msg, '温馨提示', { timeOut: 0 });
        }
        $(function () {
            // 引用自动生成的集线器代理
            var srv = $.connection.messageHub;

            // 定义服务器端调用的客户端sendMessage来显示新消息
            srv.client.sayHello = function (_msg) {
                // 向页面添加消息
                showTip(_msg);
            }

            // 注册显示个人信息的方法
            srv.client.showID = function (data) {
                console.log(data);
            }

            // 接收来自服务器的通知消息
            srv.client.showNotify = function (_msg) {
                console.log(_msg);
            }

            // 开始连接服务器
            $.connection.hub.start().done(function () {
                // 向服务器注册自己账号
                srv.server.selfIntroduction($('#hfAccounts').val());

                //console.log($.connection.hub);
                //console.log("Connected, transport = " + $.connection.hub.transport.name);
            });

        });
        // 金币显示格式化
        function goldFormat(score) {
            if ((typeof score == "number" || /\d+\.\d+/g.test(score)) && isRMB == true)
                return formatMoney(score / ExchangeRate, '');
            else
                return score;
        }
        function formatMoney(s, dot) {
            s = parseFloat((s + "").replace(/[^\d\.-]/g, "")).toFixed(2) + "";
            var l = s.split(".")[0].split("").reverse(),
                r = s.split(".")[1];
            t = "";
            for (i = 0; i < l.length; i++) {
                t += l[i] + ((i + 1) % 3 == 0 && (i + 1) != l.length ? dot : "");
            }
            //return "￥" + t.split("").reverse().join("") + "." + r;
            return t.split("").reverse().join("") + "." + r;
        }
        function saveGoldFormat(score) {
            //if ((typeof score == "number" || /\d+\.\d+/g.test(score)) && isRMB == true)
            //    return score * ExchangeRate;
            return score;
        }

        function CHEN() {
            var value = sessionStorage.getItem("language");
            if (value === "1") {
                sessionStorage.setItem("language", "0");
            } else {
                sessionStorage.setItem("language", "1");
            }
            alert(value);
        }
    </script>
