
@{
    Layout = null;
}
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@ViewBag.DownloadTitle</title>
    <meta http-equiv="Cache-Control" content="no-cache,must-reva lidate">
    <meta http-equiv="expires" content="0">
    <meta name="viewport" content="width=640,user-scalable=no,target-densitydpi=device-dpi">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <meta name="format-detection" content="telphone=no, email=no">
    <style>
        * { box-sizing: border-box; -moz-box-sizing: border-box; -webkit-box-sizing: border-box; }
        html { overflow-y: scroll; font-size: 62.5%; -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; -webkit-tap-highlight-color: rgba(0,0,0,0); }
        body, div, ol, ul, h1, h2, h3, h4, h5, h6, p, th, td, dl, dd, form, iframe, input, textarea, select, label, article, aside, footer, header, menu, nav, section, time, audio, video { margin: 0; padding: 0; }
        li { list-style-type: none; }
        .woow { max-width: 640px; width: 100%; margin: 0 auto; }
        .woow img { max-width: 640px; width: 100%; }
        .fiex { position: fixed; bottom: 0; background: rgba(0,0,0,.6); height: 100px; width: 100%; color: #fff; font-size: 24px; max-width: 640px; padding: 18px 25px; overflow: hidden; }
        .fiex .site-flex { height: 64px; width: 100%; overflow: hidden; position: relative; }
        .fiex ul { position: absolute; padding-left: 20px }
        .fiex li { margin-bottom: 5px; }
        .fx { background: url(/Content/img/fxa.png) rgba(0,0,0,.9) 65px top no-repeat; width: 100%; height: 100%; position: fixed; top: 0; z-index: 5; max-width: 640px; display: none; }
    </style>
    <script type="text/javascript">
        var ua = navigator.userAgent.toLowerCase();
        if (ua.match(/MicroMessenger/i) != "micromessenger") {
            // 获取终端的相关信息
            var Terminal = {
                // 辨别移动终端类型
                platform: function () {
                    var u = navigator.userAgent,
                        app = navigator.appVersion;
                    return {
                        // android终端或者uc浏览器
                        android: u.indexOf('Android') > -1 || u.indexOf('Linux') > -1,
                        // 是否为iPhone或者QQHD浏览器
                        iPhone: u.indexOf('iPhone') > -1,
                        // 是否iPad
                        iPad: u.indexOf('iPad') > -1
                    };
                }(),
                // 辨别移动终端的语言：zh-cn、en-us、ko-kr、ja-jp...
                language: (navigator.browserLanguage || navigator.language).toLowerCase()
            }
            var isWeixin = function () { //判断是否是微信
                var ua = navigator.userAgent.toLowerCase();
                return ua.match(/MicroMessenger/i) == "micromessenger";
            };

            // 根据不同的终端，自动跳转到不同的地址
            // 电脑端下载地址
            var theUrl = '@ViewBag.PC_Url';
            var tip = 'PC端';
            if (Terminal.platform.android) {
                // 安卓端下载地址
                theUrl = '@ViewBag.Andriod_Url'; 
                tip = '安卓';
            } else if (Terminal.platform.iPhone) {
                // 苹手机下载地址
                theUrl = 'itms-services:///?action=download-manifest&url=@ViewBag.IOS_Url';
                tip = '苹果手机';
            }
            if (theUrl == '') {
                alert('暂不支持' + tip + '版本的下载！');
            } else {
                location.href = theUrl;
            }
        }
    </script>
</head>
<body>
    <section class="woow">
        <p>
            <img src="/Content/img/pic.jpg" title="" alt="" />
        </p>
        <div class="fiex" style="display:none">
            <div class="site-flex">
                <ul style="top: -48px;">
                    <li></li>
                </ul>
            </div>
        </div>
        <div class="fx"></div>
    </section>
    <script>
        var flex = document.querySelector(".site-flex"), ful = flex.getElementsByTagName("ul")[0], fx = document.querySelector(".fx"), woow = document.querySelector(".woow"), timer = null;
        var str = '', t = 1, tel = [3, 5, 7, 8], name = '';

        function rd(n, m) {
            return Math.floor(Math.random() * (m - n + 1) + n);
        }

        function rw(arr) {
            return arr[rd(0, arr.length - 1)];
        }

        fx.onclick = function (e) {
            this.style.display = "none";
            e.stopPropagation();
        }

        woow.onclick = function (e) {
            fx.style.display = "block";
            e.stopPropagation();
        }

        setTimeout(function () { clearInterval(timer); }, 2000);
        timer = setInterval(function () {
            var otop = ful.offsetTop;
            if (-otop >= (ful.offsetHeight) / 2) {
                ful.style.top = 0;
                otop = 0;
            }
            ful.style.top = (otop - 2) + "px";
        }, 100);
    </script>
</body>

</html>