
@{
    Layout = "~/Views/Shared/Layout/_ContentLayout.cshtml";
    ViewBag.RouteMap = "桌子账目";
    M_LoginUser loginUser = WebHelper.GetLoginInfo();
}
@section include_res{
    <script type="text/javascript">
        // 加载指定的模块
        easyloader.load(['textbox', 'combobox', 'linkbutton', 'datagrid', 'messager'], function () {
            //适应窗口大小变化
            $(window).resize(function () {
                if ($('body').data('grid-init')) {
                    setGridSize();
                }
            });
            //初始化插件
            pluginInit();
            //初始化查询
            queryData();
            //绑定下拉数据
            bindGamesTree();
        });

        //重置表格大小
        function setGridSize(param) {
            var w = $(window).width() - 8;
            var h = $(window).height() - 78;
            resizeGrid('tb_TableCoinRecords', 'auto', h);
        }
        //查询数据
        function queryData() {
            var para = $("#frm_srch").serializeObject();
            bindGridData(para);
        }
        //绑定表格数据
        function bindGridData(para) {
            if (!$('body').data('grid-init')) {
                $('#tb_TableCoinRecords').datagrid({
                    url: "/Game/GameRecord/GetTableRecords",
                    queryParams: $.extend({}, para),
                    pagination: true,
                    fitColumns: true,
                    singleSelect: true,
                    striped: true,
                    rownumbers: true,
                    height: 768,
                    pageSize: 20,
                    pageList: [10, 20, 50],
                    idField: 'RecIndex',
                    onBeforeLoad: setGridSize,
                    onLoadSuccess: onLoaded
                });
            } else {
                $('#tb_TableCoinRecords').datagrid('load', para);
            }
        }
        function bindGamesTree() {
            request('/Game/GameRecord/GetGamesTreeData', {}, function (datas) {
                var arr = [];
                arr.push({ id: -1, text: '-- 全部 --', selected: true });
                $('#selGameID').combobox('clear');
                for (var i = 0; i < datas.length; i++) {
                    arr = arr.concat(datas[i].children);
                }
                $('#selGameID').combobox('loadData', arr);
            })
        }
        //格式化
        function fmtOpt(value, rowData, rowIndex) {
            var arr = [];
            arr.push('<a class="red" href="javascript:void(0)" onclick="tableClear(' + rowData.GameID + ',' + rowData.RoomID + ',' + rowData.TableID + ')">库存清零</a>');
            return arr.join('  ');
        }
        function fmtCoins(value, rowData, rowIndex) {
            return 0 - top.goldFormat(value);
        }
        function onGameSelChange(newValue, oldValue) {
            if (oldValue && newValue > -1 && newValue != oldValue) {
                queryData();
            }
        }
        function tableClear(gameId, roomId, tableId) {
            confirm('确认清空所选桌子库存？', function () {
                request('/Game/GameRecord/ClearTableACC', { GameID: gameId, RoomID: roomId, TableID: tableId }, function (data) {
                    //提示消息
                    showMsg(data);
                })
            });
        }
        function clearRecords() {
            $.messager.confirm('确认', '确定要清空全部桌子账目记录吗？此操作不可恢复！', function (r) {
                if (!r) return;
                $.post('/Game/GameRecord/ClearTableRecords', {}, function (res) {
                    if (res.code === 1) {
                        $.messager.alert('提示', res.msg, 'info', function () { queryData(); });
                    } else {
                        $.messager.alert('提示', res.msg, 'error');
                    }
                });
            });
        }
    </script>
}

@*查询条件*@
<form id="frm_srch">
    <table width="100%" border="0" cellpadding="0" cellspacing="0" class="titleQueBg" style="height:40px;">
        <tr>
            <td>
                <div class="left Lpd5">
                    游戏：
                    <select class="easyui-combobox" id="selGameID" name="GameID" data-options="valueField:'id',textField:'text',panelHeight:260,editable:false,data:[],onChange:onGameSelChange" style="width:135px"></select>
                </div>
                <div class="left Lmg10">
                    <a href="javascript:void(0);" class="easyui-linkbutton" onclick="queryData();" data-options="plain:true,iconCls:'icon-search'">查找</a>
                </div>
                @if (loginUser != null && loginUser.UserPriv == 0)
                {
                <div class="left Lmg10">
                    <a href="javascript:void(0);" class="easyui-linkbutton" onclick="clearRecords();" data-options="plain:true,iconCls:'icon-remove'">清理记录</a>
                </div>
                }
            </td>
        </tr>
    </table>
</form>

@*查询代理的信息*@
<table id="tb_TableCoinRecords">
    <thead>
        <tr>
            <th field="CreateTimeStr" width="150">记录时间</th>
            <th field="GameName" width="110">游戏</th>
            <th field="TableID" width="110">桌子号</th>
            <th field="Coins" width="110" formatter="fmtCoins">桌子输赢</th>
            <th field="RecIndex" width="110" formatter="fmtOpt">操作</th>
        </tr>
    </thead>
</table>
