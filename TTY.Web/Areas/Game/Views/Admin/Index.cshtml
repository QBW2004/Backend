</form>

@*查询代理的信息*@
<table id="tb_AgencyInfo">
    <thead>
        <tr>
            <th field="ID" width="85" formatter="fmtID">代理账号</th>
            <th field="PRIV" width="85" formatter="fmtPriv">代理层级</th>
            <th field="AGENCY" width="110">所属代理</th>
            <th field="RE_ENABLE" width="85" formatter="fmtRechargeSwitch">账号状态</th>
            <th field="AGENCY_LIMIT" width="80" formatter="fmtAgencyLimit">分代上限</th>
            <th field="PWD" width="520" formatter="fmtOpt">操作</th>
        </tr>
    </thead>
</table>

