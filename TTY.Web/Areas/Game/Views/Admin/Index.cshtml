
@{
    Layout = "~/Views/Shared/Layout/_ContentLayout.cshtml";
    ViewBag.RouteMap = "代理权限设置";
    M_LoginUser loginUser = WebHelper.GetLoginInfo();
}

@section include_res{
    <script>
        $(function () {
            // 加载指定的模块
            easyloader.load(['textbox', 'linkbutton', 'datagrid'], function () {
                //适应窗口大小变化
                $(window).resize(function () {
                    if ($('body').data('grid-init')) {
                        setGridSize();
                    }
                });
                //初始化插件
                pluginInit();
                //初始化查询
                queryData();
            });
        })
        //重置表格大小
        function setGridSize(param) {
            var w = $(window).width() - 8;
            var h = $(window).height() - 78;
            resizeGrid('tb_AgencyInfo', 'auto', h);
        }
        //查询数据
        function queryData() {
            var para = $("#frm_srch").serializeObject();
            bindGridData(para);
        }
        //绑定表格数据
        function bindGridData(para) {
            if (!$('body').data('grid-init')) {
                $('#tb_AgencyInfo').datagrid({
                    url: "/Game/AgencyInfo/GetAgencies",
                    queryParams: $.extend({}, para),
                    pagination: true,
                    fitColumns: true,
                    singleSelect: true,
                    striped: false,
                    rownumbers: true,
                    //showFooter: true,
                    height: 768,
                    pageSize: 20,
                    pageList: [10, 20, 50],
                    idField: 'ID',
                    rowStyler: agencyRowStyler,
                    onBeforeLoad: setGridSize,
                    onLoadSuccess: function () {
                        onLoaded();
                        bindAgencyRowNumberToggle();
                    }
                });
            } else {
                $('#tb_AgencyInfo').datagrid('load', para);
            }
        }
        //格式化
        function fmtRechargeSwitch(value, rowData, rowIndex) {
            if (value == 1)
                return '<span>开</span>';
            else
                return '<span class="red">关</span>';
        }
        function fmtOpt(value, rowData, rowIndex) {
            if (rowData.ID == "@(loginUser?.Accounts)")
                return "";

            var arr = [];
           
            if (rowData.IsFrozen== 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setFrozen(\'' + rowData.ID + '\',1)">启用冻结</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setFrozen(\'' + rowData.ID + '\',0)">禁用冻结</a>');
            if (rowData.IsKicking == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsKicking(\'' + rowData.ID + '\',1)">启用踢人</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsKicking(\'' + rowData.ID + '\',0)">禁用踢人</a>');
            if (rowData.IsRelease == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsRelease(\'' + rowData.ID + '\',1)">启用牌机</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsRelease(\'' + rowData.ID + '\',0)">禁用牌机</a>');
            if (rowData.IsKill == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsKill(\'' + rowData.ID + '\',1)">启用点杀</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsKill(\'' + rowData.ID + '\',0)">禁用点杀</a>');
            if (rowData.IsProbability == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setProbability(\'' + rowData.ID + '\',1)">启用放水</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setProbability(\'' + rowData.ID + '\',0)">禁用放水</a>');
            if (rowData.IsUpDown == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsUpDown(\'' + rowData.ID + '\',1)">启用上下分</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsUpDown(\'' + rowData.ID + '\',0)">禁用上下分</a>');
            if (rowData.IsDelete == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsDelete(\'' + rowData.ID + '\',1)">启用删除用户</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsDelete(\'' + rowData.ID + '\',0)">禁用删除用户</a>');
            if (rowData.IsModifyPwd == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsModifyPwd(\'' + rowData.ID + '\',1)">启用修改密码</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsModifyPwd(\'' + rowData.ID + '\',0)">禁用修改密码</a>');
            if (rowData.IsViewSafePwd == 0)
                arr.push('<a href="javascript:void(0)" class="green Lpd5" onclick="setIsViewSafePwd(\'' + rowData.ID + '\',1)">启用保险柜</a>');
            else
                arr.push('<a href="javascript:void(0)" class="red Lpd5" onclick="setIsViewSafePwd(\'' + rowData.ID + '\',0)">禁用保险柜</a>');
            arr.push('<a href="javascript:void(0)" class="blue Lpd5" onclick="setKickScope(\'' + rowData.ID + '\',' + (rowData.KickScope == 2 ? 1 : 2) + ')">踢人范围:' + (rowData.KickScope == 2 ? '整条线' : '直属') + '</a>');
            arr.push('<a href="javascript:void(0)" class="blue Lpd5" onclick="setManageScope(\'' + rowData.ID + '\',' + (rowData.ManageScope == 2 ? 1 : 2) + ')">管理范围:' + (rowData.ManageScope == 2 ? '整条线' : '直属') + '</a>');


            return arr.join('  ');
        }
        function showAdminToast(message, type) {
            var toast = $('#adminPermissionToast');
            if (toast.length < 1) {
                toast = $('<div id="adminPermissionToast"></div>').appendTo('body');
            }
            var color = '#4b89dc';
            if (type == 'success')
                color = '#3c9b5f';
            else if (type == 'danger' || type == 'error')
                color = '#d9534f';
            else if (type == 'warning')
                color = '#f0ad4e';
            toast.stop(true, true)
                .text(message)
                .css({
                    position: 'fixed',
                    top: '18px',
                    left: '50%',
                    transform: 'translateX(-50%)',
                    zIndex: 99999,
                    background: color,
                    color: '#fff',
                    padding: '10px 22px',
                    borderRadius: '4px',
                    boxShadow: '0 4px 12px rgba(0,0,0,.18)',
                    fontSize: '14px',
                    lineHeight: '20px',
                    display: 'none'
                })
                .fadeIn(120)
                .delay(5000)
                .fadeOut(180);
        }
        function showAdminResult(data) {
            if (!data)
                return;
            if (data.code == -1) {
                loginTimeoutCallback(data);
                return;
            }
            var message = data.msg ? data.msg : data.content;
            showAdminToast(message, data.code < 1 ? 'danger' : 'success');
        }
        //启用/禁用冻结
        function setFrozen(id, flag) {
            confirm('确认' + (flag == 0 ? '禁用冻结' : '启用冻结') + '所选代理的权限？', function () {
                request('/Game/Admin/SetFrozen', { ID: id, IsFrozen: flag }, function (data) {
                    //提示消息
                    showAdminResult(data);
                    if (data && data.code == 1) {
                        //queryData();//重新加载数据
                        $('#tb_AgencyInfo').datagrid('reload');
                    }
                });
            });
        }

