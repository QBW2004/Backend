
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="renderer" content="webkit">
    <title></title>
    <link href="@Url.Content("~/Content/easyui/themes/material-teal/easyui.css")" rel="stylesheet" />
    <script src="@Url.Content("~/Scripts/jquery-2.1.4.min.js")"></script>
    <script src="@Url.Content("~/Scripts/jquery.easyui.min.js")"></script>
    <script src="@Url.Content("~/Content/easyui/locale/easyui-lang-zh_CN.js")"></script>
    <script src="@Url.Content("~/Scripts/app/regist.js")"></script>
    <style>
        body { color: #404040; font-size: 14px; }
        fieldset { border: 1px solid #efefef; border-radius: 4px; width: 45%; min-width: 200px; max-width: 400px; padding: 40px; margin: 50px auto }
        legend { font-weight: bold; font-size: 18px; padding: 20px; }
        form { text-align: center }
        .rows { margin-bottom: 20px; margin-right: 32px; }
        .ctrl-box { text-align: center; padding: 5px 0 }
        .ctrl-box img { width: 96px; margin-top: 20px; margin-left: 20px; }
        .textbox { border: 1px solid #c3d9e0 !important; border-radius: 4px;width:75%;min-width:85px; max-width:320px;}
        body { font-family: "open sans", "Helvetica Neue", Helvetica, Arial, sans-serif; font-size: 14px; color: #404040; overflow-x: hidden; background: #ECDBAF; height: auto; background: url(/Content/img/login-bg.jpg) no-repeat center fixed; -webkit-background-size: cover; -moz-background-size: cover; -o-background-size: cover; background-size: cover; color: rgba(64,64,64,1) }
    </style>
</head>
<body>
    <fieldset>
        <legend>用户注册</legend>
        <form id="ff" class="easyui-form" method="post" action="@Url.Action("Register","UserInfo",new { area = "Game" })" data-options="novalidate:true">
            <div class="rows">
                <input class="easyui-textbox textbox" id="txtID" name="ID" data-options="label:'用户名：',labelAlign:'right',required:true,validType:['safeChar','minLength[6]','maxLength[20]']">
            </div>
            <div class="rows">
                <input class="easyui-textbox textbox" id="txtName" name="NAME" data-options="label:'游戏昵称：',labelAlign:'right',required:true,validType:['safeNickname','minLength[1]','maxLength[20]']">
            </div>
            <div class="rows">
                <input class="easyui-passwordbox textbox" id="txtPWD" name="PWD" data-options="label:'密码：',labelAlign:'right',required:true,validType:['safeChar','minLength[6]','maxLength[20]']">
            </div>
            <div class="rows">
                <input class="easyui-passwordbox textbox" id="txtREPWD" name="REPWD" data-options="label:'确认密码：',labelAlign:'right',required:true,validType:['safeChar','minLength[6]','maxLength[20]','confirm_pwd']">
            </div>
            <div class="ctrl-box">
                <a href="javascript:void(0)" class="easyui-linkbutton" onclick="submitForm()" style="width:80px;margin-left:20px;">注册</a>
                <a href="javascript:void(0)" class="easyui-linkbutton" onclick="clearForm()" style="width:80px;margin-left:20px;">重填</a>
            </div>
            <input type="hidden" id="hfAgency" name="AGENCY" />
            @Html.AntiForgeryToken()
            <input name="_RequestVerificationToken" type="hidden" value="@ViewBag.token" style="width:300px;" />
        </form>
        <div class="ctrl-box">
            <a href="itms-services:///?action=download-manifest&url=@ViewBag.IOS_Url" target="_blank"><img src="@Url.Content("~/Upload/iphone.png")" /></a>
            <a href="@ViewBag.Andriod_Url" target="_blank"><img src="@Url.Content("~/Upload/android.png")" /></a>
            <a href="@ViewBag.PC_Url" target="_blank"><img src="@Url.Content("~/Upload/pc.png")" /></a>
        </div>
    </fieldset>
</body>
</html>