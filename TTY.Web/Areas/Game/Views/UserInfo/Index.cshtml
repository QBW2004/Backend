        function SaveUserPwd() {
            var para = $('#form2').serializeObject();
            request('/Game/UserInfo/ChgPwd', para, function (data) {
                //提示消息
                showUserResult(data);
                if (data && data.code == 1) {
                    $('#chgWin').dialog('close');
