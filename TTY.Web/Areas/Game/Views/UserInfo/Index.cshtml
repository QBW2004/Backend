        //    $(".panel-body-noheader").eq(1).children('div').each(function (index) {
        //        $(this).on("click", function () {
        //            goFirstPage(index);
        //        });
        //    })

        //    $(".panel-body-noheader").eq(2).children('div').each(function (index) {
        //        $(this).on("click", function () {
        //            let text = $(this).text();
        //            setTimeout(function () {
        //                $("#_easyui_textbox_input14").val(text)
        //            }, 10)
        //        });
        //    })
        //},1000)
    })
    //    function goFirstPage(index) {
    //        valSelData(index)
    //}
    //重置表格大小
    function setGridSize(param) {
        var w = $(window).width() - 8;
        var h = $(window).height() - 78;
        resizeGrid('tb_UserInfo', 'auto', h);
    }
    //查询数据
    function queryData() {
        var para = $("#frm_srch").serializeObject();
        bindGridData(para);
    }
    var userInfoAutoRefreshTimer = null;
    var userInfoSilentRefreshRunning = false;
    function startUserInfoAutoRefresh() {
        if (userInfoAutoRefreshTimer) {
            clearInterval(userInfoAutoRefreshTimer);
        }
        userInfoAutoRefreshTimer = setInterval(function () {
            refreshVisibleUserRows();
        }, 3000);
    }
    function getVisibleUserIds() {
        var grid = $('#tb_UserInfo');
        if (!grid.data('datagrid')) {
            return [];
        }
        var rows = grid.datagrid('getRows') || [];
        var ids = [];
        for (var i = 0; i < rows.length; i++) {
            if (rows[i] && rows[i].ID) {
                ids.push(rows[i].ID);
            }
        }
        return ids;
    }
    function refreshVisibleUserRows() {
        refreshVisibleUserRowsByIds(getVisibleUserIds());
    }
    function refreshVisibleUserRowsByIds(ids) {
        var grid = $('#tb_UserInfo');
        if (!grid.data('datagrid') || userInfoSilentRefreshRunning || !ids || ids.length < 1) {
            return;
        }
        userInfoSilentRefreshRunning = true;
        $.ajax({
            url: '/Game/UserInfo/GetVisibleUserRows',
            type: 'POST',
            dataType: 'json',
            data: { UserIDs: JSON.stringify(ids) },
            success: function (data) {
                if (!data || data.code != 1 || !data.datas) {
                    return;
                }
                applyVisibleUserRows(data.datas);
            },
            complete: function () {
                userInfoSilentRefreshRunning = false;
            }
        });
    }
    function applyVisibleUserRows(serverRows) {
        var grid = $('#tb_UserInfo');
        var rows = grid.datagrid('getRows') || [];
        var indexById = {};
        for (var i = 0; i < rows.length; i++) {
            if (rows[i] && rows[i].ID) {
                indexById[rows[i].ID] = i;
            }
        }
        for (var j = 0; j < serverRows.length; j++) {
            var fresh = serverRows[j];
            if (!fresh || indexById[fresh.ID] == null) {
                continue;
            }
            var rowIndex = indexById[fresh.ID];
            grid.datagrid('updateRow', {
                index: rowIndex,
                row: $.extend({}, rows[rowIndex], fresh)
            });
        }
        refreshUserInfoFooter();
    }
    function refreshUserInfoFooter() {
        var rows = $('#tb_UserInfo').datagrid('getRows') || [];
        var footer = {
            FROZEN: 2,
            NAME: '合计',
            COINS: 0,
            GAME_SCORE: 0,
            COINS_BUY: 0,
            COINS_BACK: 0,
            TodayWinLoss: 0,
            Profit: 0
        };
        for (var i = 0; i < rows.length; i++) {
            footer.COINS += Number(rows[i].COINS || 0);
            footer.GAME_SCORE += Number(rows[i].GAME_SCORE || 0);
            footer.COINS_BUY += Number(rows[i].COINS_BUY || 0);
            footer.COINS_BACK += Number(rows[i].COINS_BACK || 0);
            footer.TodayWinLoss += Number(rows[i].TodayWinLoss || 0);
            footer.Profit += Number(rows[i].Profit || 0);
        }
        $('#tb_UserInfo').datagrid('reloadFooter', [footer]);
    }
    function refreshChangedUserRow(id, delay) {
        if (!id) {
            setTimeout(function () { refreshVisibleUserRows(); }, delay || 0);
            return;
        }
        setTimeout(function () { refreshVisibleUserRowsByIds([id]); }, delay || 0);
    }
    function patchVisibleUserRow(id, patch) {
        var grid = $('#tb_UserInfo');
        if (!grid.data('datagrid') || !id || !patch) {
            return;
        }
        var rowIndex = grid.datagrid('getRowIndex', id);
        if (rowIndex < 0) {
            return;
        }
        grid.datagrid('updateRow', { index: rowIndex, row: patch });
        refreshUserInfoFooter();
    }
    //绑定表格数据
    function bindGridData(para) {
        if (!$('body').data('grid-init')) {
            $('#tb_UserInfo').datagrid({
                url: "/Game/UserInfo/GetUsers",
                queryParams: $.extend({}, para),
                pagination: true,
                fitColumns: true,
                checkbox: true,
                singleSelect: false,
                striped: true,
                rownumbers: true,
                showFooter: true,
                height: 768,
                pageSize: 20,
                pageList: [10, 20, 50],
                idField: 'ID',
                //sortName: 'INHALL',
                //sortOrder: 'desc',
                //remoteSort: false,
                onBeforeLoad: setGridSize,
                onLoadSuccess: function (data) {
                    if (window.onLoaded) onLoaded(data);
                    bindRowClickMenu();
                }
            });
        } else {
            $('#tb_UserInfo').datagrid('load', para);
        }
    }
    //格式化
        function fmtForzen(value, rowData, rowIndex) {
            if (rowData.FROZEN != 2) {
                if (value == 1)
                    return '<span class="red">是</span>';
                else
                    return '<span>否</span>';

            } else {
                return '';
            }
        }
        function fmtOpt(value, rowData, rowIndex) {
            if (!rowData || rowData.FROZEN == 2) {
                return '';
            }
            var arr = [];
            if (rowData.FROZEN != 2) {
                @if (loginUser.UserPriv == 0 || loginUser.IsDelete == 1)
                {
                @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"deleteUser(\\\'' + rowData.ID + '\\\')\">删除</a>');");
                }
                // arr.push('<a href="javascript:void(0)" class="blue Lpd5" onclick="showGrade(\'' + rowData.ID + '\')">等级设置</a>');
                if (rowData.FROZEN == 1) {
                  @if (loginUser.IsFrozen == 1) {
                       @Html.Raw("arr.push('<a href=\"javascript: void(0)\" class=\"blue Lpd5\" onclick=\"frozenUser(\\\'' + rowData.ID + '\\\',0)\">解冻</a>'); ");
                  }
                }
                else {
                  @if (loginUser.IsFrozen == 1)
                  {
                       @Html.Raw("arr.push('<a href=\"javascript: void(0)\" class=\"blue Lpd5\" onclick=\"frozenUser(\\\'' + rowData.ID + '\\\',1)\">冻结</a>'); ");
                  }
                }
                 @if (loginUser.UserPriv == 0 || loginUser.IsKill == 1 || loginUser.IsProbability == 1 || loginUser.IsRelease == 1)
                 {
                      @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"showCtrlSelect(\\\'' + rowData.ID + '\\\')\">控制</a>');");
                 }
                @*鱼机控制已合并到「控制」按钮*@
                @*牌机控制已合并到「控制」按钮*@
                @*注机控制已合并到「控制」按钮*@
                @if (loginUser.UserPriv == 0 || loginUser.IsKicking == 1)
                 {
                    @Html.Raw("if (canKickWholeLine || rowData.AGENCY == loginAgencyAccount) {");
                      @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"kickPlayer(\\\'' + rowData.ID + '\\\')\">踢人</a>');");
                    @Html.Raw("}");
                 }
            }
            @if (loginUser.UserPriv == 0 || loginUser.IsUpDown == 1)
            {
            @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"showReChange(\\\'' + rowData.ID + '\\\')\">充值</a>');");
            }
            // arr.push('<a href="javascript:void(0)" class="blue Lpd5" onclick="showGive(\'' + rowData.ID + '\')">赠送</a>');
            @if (loginUser.UserPriv == 0 || loginUser.IsUpDown == 1)
            {
            @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"showDeduct(\\\'' + rowData.ID + '\\\')\">扣币</a>');");
            }
            @if (false)
            {
            @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"showChgSafePwdWin(\\\'' + rowData.ID + '\\\')\">修改保险柜密码</a>');");
            }
            @if (loginUser.UserPriv == 0 || loginUser.IsModifyPwd == 1)
            {
            @Html.Raw("arr.push('<a href=\"javascript:void(0)\" class=\"blue Lpd5\" onclick=\"showChgWin(\\\'' + rowData.ID + '\\\')\">修改密码</a>');");
            }
            return arr.join('  ');
        }
        function fmtCoins(value, rowData, rowIndex) {
            return top.goldFormat(value);
        }
        function fmtWinLoss(value, rowData, rowIndex) {
            var num = Number(value || 0);
            var color = num > 0 ? '#3c9b5f' : (num < 0 ? '#d9534f' : '#333');
            return '<span style="color:' + color + '">' + top.goldFormat(num) + '</span>';
        }
        function showUserToast(message, type) {
            var toast = $('#userInfoToast');
            if (toast.length < 1) {
                toast = $('<div id="userInfoToast"></div>').appendTo('body');
            }
            var color = '#4b89dc';
            if (type == 'success')
                color = '#3c9b5f';
            else if (type == 'danger' || type == 'error')
                color = '#d9534f';
            else if (type == 'warning')
                color = '#f0ad4e';
            toast.stop(true, true)
                .text(message)
                .css({
                    position: 'fixed',
                    top: '18px',
                    left: '50%',
                    transform: 'translateX(-50%)',
                    zIndex: 99999,
                    background: color,
                    color: '#fff',
                    padding: '10px 22px',
                    borderRadius: '4px',
                    boxShadow: '0 4px 12px rgba(0,0,0,.18)',
                    fontSize: '14px',
                    lineHeight: '20px',
                    display: 'none'
                })
                .fadeIn(120)
                .delay(5000)
                .fadeOut(180);
        }
        function showUserResult(data, dangerOnSuccess) {
            if (!data)
                return;
            if (data.code == -1) {
                loginTimeoutCallback(data);
                return;
            }
            var message = data.msg ? data.msg : data.content;
            var type = data.code < 1 ? 'danger' : (dangerOnSuccess ? 'danger' : 'success');
            showUserToast(message, type);
        }
        function frozenUser(id, flag) {
            confirm('确认' + (flag == 0 ? '解冻' : '冻结') + '选定的用户？', function () {
                request('/Game/UserInfo/FrozenUser', { ID: id, frozen: flag }, function (data) {
                    //提示消息
                    showUserResult(data);
                    if (data && data.code == 1) {
                        patchVisibleUserRow(id, { FROZEN: flag });
                        refreshChangedUserRow(id, 300);
                    }
                });
            });
        }
        function deleteUser(id) {
             @Html.Raw(@"        confirm('确认删除所选用户？', function () {
                request('/Game/UserInfo/DelUser', { ID: id }, function (data) {
                    //提示消息
                    showUserResult(data, data && data.code == 1);
                    if (data && data.code == 1) {
                        queryData();//重新加载数据
                    }
                });
            });");
        }

