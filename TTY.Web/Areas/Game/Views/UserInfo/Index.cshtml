        function loadGoldLimit(uid, inputId) {
            $('#' + inputId).numberbox('setValue', 0);
            if (!uid) return;
            $.post('/Game/UserInfo/GetUserGoldLimit', { ID: uid }, function (data) {
                if (data && data.code == 1 && data.content) {
                    $('#' + inputId).numberbox('setValue', parseInt(data.content) || 0);
                }
            });
        }
