        function resetPlayerCoins(tipId, btnId) {
            $(tipId).text('--');
            $(btnId).linkbutton('disable');
        }
        function bindUserRechargeCoinTriggers() {
            var queryRechargeByEnter = function (e) {
                if (e.which == 13) {
                    e.preventDefault();
                    QueryPlayerCoins('#hfUID3', '#txtCurrentCoins_Recharge', '#btnSaveReChange');
                }
            };
            var queryDeductByEnter = function (e) {
                if (e.which == 13) {
                    e.preventDefault();
                    QueryPlayerCoins('#hfUID5', '#txtCurrentCoins_Deduct', '#btnSaveDeduct');
                }
            };
            $('#txtE_UID3').textbox();
            $('#txtE_UID3').textbox('textbox')
                .on('blur', function () { QueryPlayerCoins('#hfUID3', '#txtCurrentCoins_Recharge', '#btnSaveReChange'); })
                .on('keydown', queryRechargeByEnter);
            $('#txtE_UID5').textbox();
            $('#txtE_UID5').textbox('textbox')
                .on('blur', function () { QueryPlayerCoins('#hfUID5', '#txtCurrentCoins_Deduct', '#btnSaveDeduct'); })
                .on('keydown', queryDeductByEnter);
        }
        function QueryPlayerCoins(hiddenId, tipId, btnId) {
            var id = $(hiddenId).val();
            request('/Game/UserInfo/QueryPlayerCoins', { ID: id }, function (data) {
                if (data && data.code == 1) {
                    $(tipId).text(top.goldFormat(data.datas.displayCoins || data.datas.coins || 0));
                    $(btnId).linkbutton('enable');
                } else {
                    showUserResult(data);
                }
            });
        }

