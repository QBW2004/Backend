    var canKickWholeLine = @((loginUser?.UserPriv == 0 || loginUser?.ManageScope == 2).ToString().ToLower());
    var loginAgencyAccount = "@(loginUser?.Accounts)";
    var canDelete = @((loginUser?.UserPriv == 0 || loginUser?.IsDelete == 1).ToString().ToLower());
    var canControl = @((loginUser?.UserPriv == 0 || loginUser?.IsKill == 1 || loginUser?.IsProbability == 1 || loginUser?.IsRelease == 1).ToString().ToLower());
    var canKick = @((loginUser?.UserPriv == 0 || loginUser?.IsKicking == 1).ToString().ToLower());
    var canUpDown = @((loginUser?.UserPriv == 0 || loginUser?.IsUpDown == 1).ToString().ToLower());
    var canModifyPwd = @((loginUser?.UserPriv == 0 || loginUser?.IsModifyPwd == 1).ToString().ToLower());
    $(function () {
