        function showMenuModal() {
            var dlg = $('#menuModal');
            if (!_menuInited) {
                dlg.dialog({
                    title: '【功能菜单】',
                    width: 320,
                    height: 440,
                    modal: true,
                    closed: true,
                    collapsible: false,
                    minimizable: false,
                    maximizable: false,
                    resizable: false
                });
                _menuInited = true;
            }
            dlg.dialog('open');
        }

        function closeMenu() {
            $('#menuModal').dialog('close');
        }

        function menuDelete() { closeMenu(); deleteUser(_menuUser.ID); }
        function menuControl() { closeMenu(); showCtrlSelect(_menuUser.ID); }
        function menuKick() { closeMenu(); kickPlayer(_menuUser.ID); }
        function menuRecharge() { closeMenu(); showReChange(_menuUser.ID); }
        function menuDeduct() { closeMenu(); showDeduct(_menuUser.ID); }
        function menuChgPwd() { closeMenu(); showChgWin(_menuUser.ID); }

        function bindRowClickMenu() {
            if (bindRowClickMenu._done) return;
            bindRowClickMenu._done = true;
            document.addEventListener('click', function (e) {
                if (!e.target || !e.target.closest) return;
                var row = e.target.closest('tr.datagrid-row');
                if (!row) return;
                var panel = $('#tb_UserInfo').datagrid('getPanel');
                if (!panel.length || !panel[0].contains(row)) return;
                if (e.target.closest('a') || e.target.closest('input[type=checkbox]')) return;
                var idx = parseInt(row.getAttribute('datagrid-row-index'));
                if (isNaN(idx)) return;
                var rows = $('#tb_UserInfo').datagrid('getRows');
                var rd = rows[idx];
                if (rd && rd.FROZEN != 2) {
                    _menuUser = rd;
                    $('#menuUserAccount').text(rd.ID || '');
                    $('#menuUserName').text(rd.NAME || '');
                    if (canKick && (canKickWholeLine || rd.AGENCY == loginAgencyAccount))
                        $('#menuBtnKick').show();
                    else
                        $('#menuBtnKick').hide();
                    showMenuModal();
                }
            }, true);
        }
