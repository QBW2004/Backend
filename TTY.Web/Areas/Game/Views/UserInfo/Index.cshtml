        easyloader.load(['textbox', 'linkbutton', 'datagrid', 'dialog'], function () {
            //适应窗口大小变化
            $(window).resize(function () {
                if ($('body').data('grid-init')) {
                    setGridSize();
                }
            });
            //初始化插件
            pluginInit();
            bindUserRechargeCoinTriggers();
            //初始化查询
            queryData();
            startUserInfoAutoRefresh();
        });


