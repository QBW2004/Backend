                    $('#selE_Val_Laba').combobox('loadData', getComboValKill());
                    $('#hfLabaMode').val(0);
                    loadGoldLimit(uid, 'numGoldLimitLaba');
                    loadUserCtrlConfigs(uid, function(data) {
                        if (data && data.length > 0) {
