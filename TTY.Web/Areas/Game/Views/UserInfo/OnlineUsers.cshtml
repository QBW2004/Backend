    function bindGameTypePaiJi(newValue, oldValue) {
        if (oldValue && newValue > -1 && newValue != oldValue) {
            if (newValue == 5 || newValue == 12 || newValue == 13 || newValue == 14) {
                $('#selE_Type').combobox('loadData', valSelDataPAIJI3())
            } else {
