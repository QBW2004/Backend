                    refreshChangedUserRow(id, 800);
                }
            });
        }); ")
    }

    function bindAction(newValue, oldValue) {
        if (oldValue && newValue > -1 && newValue != oldValue) {
            if (newValue == 1) {
                $('#selE_Val1').combobox('loadData', getComboValKill());
            } else if (newValue == 2) {
                $('#selE_Val1').combobox('loadData', getComboValPut());
            } else if (newValue == 3) {
                $('#selE_Val2').combobox('loadData', getComboValKill());
            } else {
                $('#selE_Val2').combobox('loadData', getComboValPut());
            }

        }
    }

    function getComboValKill() {
        var arr = [];
        arr.push({ id: 3, text: '小杀(3%)' });
        arr.push({ id: 6, text: '中杀(6%)', selected: true });
        arr.push({ id: 9, text: '大杀(9%)' });
        arr.push({ id: 0, text: '关闭' });
        return arr;
    }
    function getComboValPut() {
        var arr = [];
        arr.push({ id: 3, text: '小放(3%)', selected: true });
        arr.push({ id: 6, text: '中放(6%)' });
        arr.push({ id: 9, text: '大放(9%)' });
        arr.push({ id: 0, text: '关闭' });
        return arr;
    }

    var _menuUser = null;
    var _menuInited = false;

    function showMenuModal() {
        var dlg = $('#menuModal');
        if (!_menuInited) {
            dlg.dialog({
                title: '【功能菜单】',
                width: 320,
                height: 440,
                modal: true,
                closed: true,
                collapsible: false,
                minimizable: false,
                maximizable: false,
                resizable: false
            });
            _menuInited = true;
        }
        dlg.dialog('open');
    }

    function closeMenu() {
        $('#menuModal').dialog('close');
    }

    function menuDelete() { closeMenu(); deleteUser(_menuUser.ID); }
    function menuControl() { closeMenu(); showCtrlSelect(_menuUser.ID); }
    function menuKick() { closeMenu(); kickPlayer(_menuUser.ID); }
    function menuRecharge() { closeMenu(); showReChange(_menuUser.ID); }
    function menuDeduct() { closeMenu(); showDeduct(_menuUser.ID); }
    function menuChgPwd() { closeMenu(); showChgWin(_menuUser.ID); }

    function bindOnlineRowClick() {
        if (bindOnlineRowClick._done) return;
        bindOnlineRowClick._done = true;
        document.addEventListener('click', function (e) {
            if (!e.target || !e.target.closest) return;
            var row = e.target.closest('tr.datagrid-row');
            if (!row) return;
            var panel = $('#tb_OnlineUsers').datagrid('getPanel');
            if (!panel.length || !panel[0].contains(row)) return;
            if (e.target.closest('a') || e.target.closest('input[type=checkbox]')) return;
            var idx = parseInt(row.getAttribute('datagrid-row-index'));
            if (isNaN(idx)) return;
            var rows = $('#tb_OnlineUsers').datagrid('getRows');
            var rd = rows[idx];
            if (rd) {
                _menuUser = rd;
                $('#menuUserAccount').text(rd.ID || '');
                $('#menuUserName').text(rd.NAME || '');
                if (canKick && (canKickWholeLine || rd.AGENCY == loginAgencyAccount))
                    $('#menuBtnKick').show();
                else
                    $('#menuBtnKick').hide();
                showMenuModal();
            }
        }, true);
    }
