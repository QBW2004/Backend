@*功能菜单弹窗*@
<div id="menuModal" class="hide" style="text-align:center;padding:20px 20px 16px;">
    <div style="font-size:18px;font-weight:bold;color:#303133;margin-bottom:4px;">玩家账号：<span id="menuUserAccount" style="color:#409eff;"></span></div>
    <div style="font-size:14px;color:#909399;margin-bottom:20px;padding-bottom:14px;border-bottom:1px solid #ebeef5;">名称：<span id="menuUserName"></span></div>
    <div>
        @if (loginUser.UserPriv == 0 || loginUser.IsDelete == 1)
        {
            <a href="javascript:void(0);" class="menu-btn-item menu-btn-delete" onclick="menuDelete()">删除</a>
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsKill == 1 || loginUser.IsProbability == 1 || loginUser.IsRelease == 1)
        {
            <a href="javascript:void(0);" class="menu-btn-item menu-btn-control" onclick="menuControl()">控制</a>
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsKicking == 1)
        {
            <a href="javascript:void(0);" id="menuBtnKick" class="menu-btn-item menu-btn-kick" onclick="menuKick()">踢人</a>
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsUpDown == 1)
        {
            <a href="javascript:void(0);" class="menu-btn-item menu-btn-recharge" onclick="menuRecharge()">充值</a>
            <a href="javascript:void(0);" class="menu-btn-item menu-btn-deduct" onclick="menuDeduct()">扣币</a>
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsModifyPwd == 1)
        {
            <a href="javascript:void(0);" class="menu-btn-item menu-btn-pwd" onclick="menuChgPwd()">修改密码</a>
        }
        <a href="javascript:void(0);" class="menu-btn-item menu-btn-back" onclick="closeMenu()">返回</a>
    </div>
</div>
