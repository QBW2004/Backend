
@{
    Layout = "~/Views/Shared/Layout/_ContentLayout.cshtml";
    ViewBag.RouteMap = "在线用户";
    M_LoginUser loginUser = WebHelper.GetLoginInfo();
}

@section include_res{
    <script>
    var canKickWholeLine = @((loginUser?.UserPriv == 0 || loginUser?.ManageScope == 2).ToString().ToLower());
    var loginAgencyAccount = "@(loginUser?.Accounts)";
    var canKick = @((loginUser?.UserPriv == 0 || loginUser?.IsKicking == 1).ToString().ToLower());
    $(function () {
        easyloader.load(['textbox', 'linkbutton', 'datagrid', 'dialog'], function () {
            $(window).resize(function () {
                if ($('body').data('grid-init')) {
                    setGridSize();
                }
            });
            pluginInit();
            bindUserRechargeCoinTriggers();
            loadGames();
            initGrid();
        });
    })

    var _gamesCache = [];
    function loadGames() {
        request('/api/Games', {}, function (data) {
            if (data && data.length) _gamesCache = data;
        }, 'GET');
    }
    function getGameName(gameId) {
        if (!gameId || gameId <= 0) return '--';
        for (var i = 0; i < _gamesCache.length; i++) {
            if (_gamesCache[i] && _gamesCache[i].GameId == gameId)
                return _gamesCache[i].Name;
        }
        return '游戏' + gameId;
    }

    function setGridSize() {
        var w = $(window).width() - 8;
        var h = $(window).height() - 78;
        resizeGrid('tb_OnlineUsers', 'auto', h);
    }

    function initGrid() {
        if (!$('body').data('grid-init')) {
            $('#tb_OnlineUsers').datagrid({
                fitColumns: true,
                singleSelect: true,
                striped: true,
                rownumbers: true,
                height: 768,
                idField: 'ID',
                onBeforeLoad: function () { setGridSize(); }
            });
        }
        queryData();
    }

    function queryData() {
        var srch = $('#frm_srch').serializeObject();
        request('/Game/UserInfo/GetOnlineUsers', srch, function (data) {
            if (data && data.code == 1) {
                var rows = data.datas || [];
                var keyword = ($('#frm_srch').find('[name="srch_ID"]').val() || '').toLowerCase();
                var kwName = ($('#frm_srch').find('[name="srch_NAME"]').val() || '').toLowerCase();
                var kwAgency = ($('#frm_srch').find('[name="srch_Agency"]').val() || '').toLowerCase();
                if (keyword) rows = rows.filter(function (r) { return (r.ID || '').toLowerCase().indexOf(keyword) >= 0; });
                if (kwName) rows = rows.filter(function (r) { return (r.NAME || '').toLowerCase().indexOf(kwName) >= 0; });
                if (kwAgency) rows = rows.filter(function (r) { return (r.AGENCY || '').toLowerCase().indexOf(kwAgency) >= 0; });
                $('#tb_OnlineUsers').datagrid('loadData', { total: rows.length, rows: rows });
                $('#spCount').text('共 ' + rows.length + ' 人在线');
                bindOnlineRowClick();
            } else {
                showMsg(data);
            }
        });
    }

    function fmtCoins(value) {
        return top.goldFormat(value || 0);
    }
    // 剩余分数 = 大厅金币(Coins) + 带进游戏内的分(Score)，即账号总金币
    function fmtTotalCoins(value, row) {
        return top.goldFormat((row.Coins || 0) + (row.Score || 0));
    }
    function fmtWinLoss(value) {
        var v = value || 0;
        var color = v > 0 ? '#2e8b57' : (v < 0 ? '#c0392b' : '#666');
        return '<span style="color:' + color + ';">' + top.goldFormat(v) + '</span>';
    }
    function fmtStatus(value) {
        if (value === 0) return '<span style="color:#2e8b57;">游戏中</span>';
        if (value === 1) return '<span style="color:#999;">大厅</span>';
        return '<span style="color:#aaa;">其他</span>';
    }
    function fmtGame(value) {
        return getGameName(value);
    }
    function fmtTable(value) {
        if (value == null || value < 0) return '--';
        return (parseInt(value, 10) + 1) + '号桌';
    }
    function fmtSeat(value) {
        if (value == null || value < 0) return '--';
        return (parseInt(value, 10) + 1) + '号位';
    }

    var _autoTimer = null;
    function toggleAutoRefresh() {
        if (_autoTimer) { clearInterval(_autoTimer); _autoTimer = null; }
        if ($('#chkAutoRefresh').is(':checked')) {
            var sec = parseInt($('#selRefreshSec').val(), 10) || 10;
            _autoTimer = setInterval(queryData, sec * 1000);
        }
    }

    function refreshChangedUserRow(id, delay) {
        setTimeout(queryData, delay || 0);
    }
    function showUserToast(message, type) {
        var toast = $('#userInfoToast');
        if (toast.length < 1) {
            toast = $('<div id="userInfoToast"></div>').appendTo('body');
        }
        var color = '#4b89dc';
        if (type == 'success')
            color = '#3c9b5f';
        else if (type == 'danger' || type == 'error')
            color = '#d9534f';
        else if (type == 'warning')
            color = '#f0ad4e';
        toast.stop(true, true)
            .text(message)
            .css({
                position: 'fixed',
                top: '18px',
                left: '50%',
                transform: 'translateX(-50%)',
                zIndex: 99999,
                background: color,
                color: '#fff',
                padding: '10px 22px',
                borderRadius: '4px',
                boxShadow: '0 4px 12px rgba(0,0,0,.18)',
                fontSize: '14px',
                lineHeight: '20px',
                display: 'none'
            })
            .fadeIn(120)
            .delay(5000)
            .fadeOut(180);
    }
    function showUserResult(data, dangerOnSuccess) {
        if (!data)
            return;
        if (data.code == -1) {
            loginTimeoutCallback(data);
            return;
        }
        var message = data.msg ? data.msg : data.content;
        var type = data.code < 1 ? 'danger' : (dangerOnSuccess ? 'danger' : 'success');
        showUserToast(message, type);
    }
    function deleteUser(id) {
         @Html.Raw(@"        confirm('确认删除所选用户？', function () {
            request('/Game/UserInfo/DelUser', { ID: id }, function (data) {
                //提示消息
                showUserResult(data, data && data.code == 1);
                if (data && data.code == 1) {
                    queryData();//重新加载数据
                }
            });
        });")
    }

    function showChgWin(uid) {
        var para = {
            winId: '#chgWin',
            title: '【修改密码】',
            iconCls: 'icon-user-edit',
            callBack: function () {
                $('#txtE_UID').textbox('setValue', uid);
                $('#hfUID').val(uid);
            }
        };
        openWin(para);
    }

    function showReChange(uid) {
        var para = {
            winId: '#chgReChange',
            title: '【用户充值】',
            iconCls: 'icon-user-edit',
            callBack: function () {
                $('#txtE_UID3').textbox('setValue', uid);
                $('#hfUID3').val(uid);
                resetPlayerCoins('#txtCurrentCoins_Recharge', '#btnSaveReChange');
                QueryPlayerCoins('#hfUID3', '#txtCurrentCoins_Recharge', '#btnSaveReChange');
            }
        };
        openWin(para);
    }

    function showDeduct(uid) {
        var para = {
            winId: '#chgDeduct',
            title: '【用户扣币】',
            iconCls: 'icon-user-edit',
            callBack: function () {
                $('#txtE_UID5').textbox('setValue', uid);
                $('#hfUID5').val(uid);
                resetPlayerCoins('#txtCurrentCoins_Deduct', '#btnSaveDeduct');
                QueryPlayerCoins('#hfUID5', '#txtCurrentCoins_Deduct', '#btnSaveDeduct');
            }
        };
        openWin(para);
    }

    function SaveUserPwd() {
        var para = $('#form2').serializeObject();
        request('/Game/UserInfo/ChgPwd', para, function (data) {
            //提示消息
            showUserResult(data);
            if (data && data.code == 1) {
                $('#chgWin').dialog('close');
                $('#form2').form('reset');
                refreshChangedUserRow(para.ID, 300);
            }
        });
    }

    function SaveReChange() {
        var para = $('#form8').serializeObject();
        request('/Game/UserInfo/SaveReChange', para, function (data) {
            //提示消息
            showUserResult(data);
            if (data && data.code == 1) {
                $('#chgReChange').dialog('close');
                $('#form8').form('reset');
                refreshChangedUserRow(para.ID3, 500);
            }
        });
    }
    function resetPlayerCoins(tipId, btnId) {
        $(tipId).text('--');
        $(btnId).linkbutton('disable');
    }
    function bindUserRechargeCoinTriggers() {
        var queryRechargeByEnter = function (e) {
            if (e.which == 13) {
                e.preventDefault();
                QueryPlayerCoins('#hfUID3', '#txtCurrentCoins_Recharge', '#btnSaveReChange');
            }
        };
        var queryDeductByEnter = function (e) {
            if (e.which == 13) {
                e.preventDefault();
                QueryPlayerCoins('#hfUID5', '#txtCurrentCoins_Deduct', '#btnSaveDeduct');
            }
        };
        $('#txtE_UID3').textbox();
        $('#txtE_UID3').textbox('textbox')
            .on('blur', function () { QueryPlayerCoins('#hfUID3', '#txtCurrentCoins_Recharge', '#btnSaveReChange'); })
            .on('keydown', queryRechargeByEnter);
        $('#txtE_UID5').textbox();
        $('#txtE_UID5').textbox('textbox')
            .on('blur', function () { QueryPlayerCoins('#hfUID5', '#txtCurrentCoins_Deduct', '#btnSaveDeduct'); })
            .on('keydown', queryDeductByEnter);
    }
    function QueryPlayerCoins(hiddenId, tipId, btnId) {
        var id = $(hiddenId).val();
        request('/Game/UserInfo/QueryPlayerCoins', { ID: id }, function (data) {
            if (data && data.code == 1) {
                $(tipId).text(top.goldFormat(data.datas.displayCoins || data.datas.coins || 0));
                $(btnId).linkbutton('enable');
            } else {
                showUserResult(data);
            }
        });
    }

    function SaveDeduct() {
        var para = $('#form10').serializeObject();
        request('/Game/UserInfo/SaveDeduct', para, function (data) {
            //提示消息
            showUserResult(data);
            if (data && data.code == 1) {
                $('#chgDeduct').dialog('close');
                $('#form10').form('reset');
                refreshChangedUserRow(para.ID5, 500);
            }
        });
    }

    function loadGoldLimit(uid, inputId) {
        $('#' + inputId).numberbox('setValue', 0);
        if (!uid) return;
        $.post('/Game/UserInfo/GetUserGoldLimit', { ID: uid }, function (data) {
            if (data && data.code == 1 && data.content) {
                $('#' + inputId).numberbox('setValue', parseInt(data.content) || 0);
            }
        });
    }
    function showRateCtrlWin(uid) {
        var para = {
            winId: '#chgRateWin',
            title: '【鱼机控制】',
            iconCls: 'icon-chart_curve',
            callBack: function () {
                $('#txtE_ID').textbox('setValue', uid);
                $('#hfID').val(uid);
                $('#selE_Action1').combobox('loadData', actionSelData());
                $('#selE_Val1').combobox('loadData', getComboValKill());
                loadGoldLimit(uid, 'numGoldLimit1');
            }
        };
        openWin(para);
    }
    function showRateCtrlWinBet(uid) {
        var para = {
            winId: '#chgRateWinBet',
            title: '【注机控制】',
            iconCls: 'icon-chart_curve',
            callBack: function () {
                $('#txtE_ID11').textbox('setValue', uid);
                $('#hfID11').val(uid);
                $('#selE_Action2').combobox('loadData', actionSelDataBet());
                $('#selE_Val2').combobox('loadData', getComboValKill());
                loadGoldLimit(uid, 'numGoldLimit2');
            }
        };
        openWin(para);
    }
    function showRateCtrlWinPAIJI(uid) {
        var para = {
            winId: '#chgRateWinPAIJI',
            title: '【牌机控制】',
            iconCls: 'icon-chart_curve',
            callBack: function () {
                $('#txtE_ID1').textbox('setValue', uid);
                $('#hfID1').val(uid);
                $('#selE_Mode').combobox({
                    onChange: function(n) {
                        if (n == 1) { $('.trPaiJiCtrl').show(); $('.trPaiJiKill').hide(); $('#hfPaiJiMode').val(0); }
                        else { $('.trPaiJiCtrl').hide(); $('.trPaiJiKill').show(); $('#hfPaiJiMode').val(1); }
                    }
                });
                $('#selE_Mode').combobox('loadData', [{id:1,text:'控牌',selected:true},{id:2,text:'点杀'}]);
                $('#selE_KillVal').combobox('loadData', getComboValKill());
                $('#hfPaiJiMode').val(0);
                $('#selE_Action').combobox('loadData', actionSelDataPAIJI());
                loadGoldLimit(uid, 'numGoldLimit3');
                loadUserCtrlConfigs(uid, function(data) {
                    if (data && data.length > 0) {
                        var row = data[0];
                        if (row.CtrlType >= 5 && row.CtrlType <= 14) {
                            $('#selE_Action').combobox('setValue', row.CtrlType);
                            $('#selE_Type').combobox('setValue', row.CtrlValue);
                            $('#selE_Number').combobox('setValue', row.Number);
                            $('#selE_Val').combobox('setValue', row.TotalNumber);
                        }
                    }
                });
            }
        };
        openWin(para);
    }
    function showRateCtrlWinLaba(uid) {
        var para = {
            winId: '#chgRateWinLaba',
            title: '【拉霸控制】',
            iconCls: 'icon-chart_curve',
            callBack: function () {
                $('#txtE_ID_Laba').textbox('setValue', uid);
                $('#hfID_Laba').val(uid);
                $('#selE_Action_Laba').combobox({ onChange: bindLabaAction });
                $('#selE_Action_Laba').combobox('loadData', actionSelDataLaba());
                $('#selE_Symbol_Laba').combobox('loadData', valSelDataShz());
                $('#selE_Number_Laba').combobox('loadData', valSelData());
                $('#selE_Total_Laba').combobox('loadData', valSelDataPAIJI1());
                $('#selE_ModeLaba').combobox({
                    onChange: function(n) {
                        if (n == 1) { $('.trLabaCtrl').show(); $('.trLabaKill').hide(); $('#hfLabaMode').val(0); }
                        else { $('.trLabaCtrl').hide(); $('.trLabaKill').show(); $('#hfLabaMode').val(1); }
                    }
                });
                $('#selE_ModeLaba').combobox('loadData', [{id:1,text:'控牌',selected:true},{id:2,text:'点杀'}]);
                $('#selE_Val_Laba').combobox('loadData', getComboValKill());
                $('#hfLabaMode').val(0);
                loadGoldLimit(uid, 'numGoldLimitLaba');
                loadUserCtrlConfigs(uid, function(data) {
                    if (data && data.length > 0) {
                        var row = data[0];
                        if (row.CtrlType >= 15 && row.CtrlType <= 17) {
                            $('#selE_Action_Laba').combobox('setValue', row.CtrlType);
                            $('#selE_Symbol_Laba').combobox('setValue', row.CtrlValue);
                            $('#selE_Number_Laba').combobox('setValue', row.Number);
                            $('#selE_Total_Laba').combobox('setValue', row.TotalNumber);
                            bindLabaAction(row.CtrlType);
                        }
                    }
                });
            }
        };
        openWin(para);
    }
    function loadUserCtrlConfigs(uid, callback) {
        if (!uid) { callback([]); return; }
        $.post('/Game/UserInfo/GetUserCtrlConfigs', { ID: uid }, function(data) {
            if (data && data.code == 1 && data.datas) { callback(data.datas); }
            else { callback([]); }
        });
    }

    @*合并控制按钮选择窗口*@
    function showCtrlSelect(uid) {
        var para = {
            winId: '#chgCtrlSelect',
            title: '【控制】',
            iconCls: 'icon-chart_curve',
            width: 280,
            height: 200,
            callBack: function () {
                $('#chgCtrlSelect').data('uid', uid);
                var canFish = @Html.Raw((loginUser.UserPriv == 0 || loginUser.IsKill == 1 || loginUser.IsProbability == 1) ? "true" : "false");
                var canPaiJi = @Html.Raw((loginUser.UserPriv == 0 || loginUser.IsRelease == 1) ? "true" : "false");
                var canBet = @Html.Raw((loginUser.UserPriv == 0 || loginUser.IsKill == 1 || loginUser.IsProbability == 1) ? "true" : "false");
                if (canFish) $('#btnFishCtrl').show(); else $('#btnFishCtrl').hide();
                if (canPaiJi) $('#btnPaiJiCtrl').show(); else $('#btnPaiJiCtrl').hide();
                if (canBet) $('#btnBetCtrl').show(); else $('#btnBetCtrl').hide();
                var canLaba = canBet;
                if (canLaba) $('#btnLabaCtrl').show(); else $('#btnLabaCtrl').hide();
            }
        };
        openWin(para);
    }
    function subCtrlClick(type) {
        var uid = $('#chgCtrlSelect').data('uid');
        $('#chgCtrlSelect').dialog('close');
        if (type == 'fish') showRateCtrlWin(uid);
        else if (type == 'paiji') showRateCtrlWinPAIJI(uid);
        else if (type == 'bet') showRateCtrlWinBet(uid);
        else if (type == 'laba') showRateCtrlWinLaba(uid);
    }
    function actionSelData() {
        var items = [];
        @if (loginUser.UserPriv == 0 || loginUser.IsKill == 1)
        {
            @Html.Raw("items.push({ id: 1, text: '鱼机点杀' });");
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsProbability == 1)
        {
            @Html.Raw("items.push({ id: 2, text: '鱼机放水' });");
        }
        if (items.length > 0) items[0].selected = true;
        return items;
    }

    function actionSelDataBet() {
        var items = [];
        @if (loginUser.UserPriv == 0 || loginUser.IsKill == 1)
        {
            @Html.Raw("items.push({ id: 3, text: '注机点杀' });");
        }
        @if (loginUser.UserPriv == 0 || loginUser.IsProbability == 1)
        {
            @Html.Raw("items.push({ id: 4, text: '注机放水' });");
        }
        if (items.length > 0) items[0].selected = true;
        return items;
    }

