
@{
    Layout = "~/Views/Shared/Layout/_ContentLayout.cshtml";
    ViewBag.RouteMap = "充值记录";
    M_LoginUser loginUser = WebHelper.GetLoginInfo();
}

@section include_res{
<script>
        $(function () {
            // 加载指定的模块
            easyloader.load(['textbox', 'linkbutton', 'datagrid', 'messager'], function () {
                //适应窗口大小变化
                $(window).resize(function () {
                    if ($('body').data('grid-init')) {
                        setGridSize();
                    }
                });
                //初始化插件
                pluginInit();
                //初始化查询
                queryData();
            });
        })
        //重置表格大小
        function setGridSize(param) {
            var w = $(window).width() - 8;
            var h = $(window).height() - 78;
            resizeGrid('tb_ReChargeRecords', 'auto', h);
        }
        //查询数据
        function queryData() {
            var para = $("#frm_srch").serializeObject();
            bindGridData(para);
        }
        //绑定表格数据
        function bindGridData(para) {
            if (!$('body').data('grid-init')) {
                $('#tb_ReChargeRecords').datagrid({
                    url: "/Game/Recharge/GetReChargeRecords",
                    queryParams: $.extend({}, para),
                    pagination: true,
                    fitColumns: true,
                    singleSelect: true,
                    striped: true,
                    rownumbers: true,
                    showFooter: true,  
                    height: 768,
                    pageSize: 20,
                    pageList: [10, 20, 50],
                    idField: 'USER',
                    onBeforeLoad: setGridSize,
                    onLoadSuccess: onLoaded
                });
            } else {
                $('#tb_ReChargeRecords').datagrid('load', para);
            }   

        }
        function fmtProcessed(value, rowData, rowIndex) {
            if (value == 1)
                return '<span class="green">已处理</span>';
            else if (value == 0)
                return '<span class="red">未处理</span>';
            else if (value == 2)
                return '<span class="red">拒绝处理</span>';
            else if (value == 3)
                return '<span class="red">拒绝并扣币</span>';
        }
        function fmtOpt(value, rowData, rowIndex) {
            if (rowData.Processed == 4) {
                return rowData.OrderNo || '';
            }
            var arr = [];
            if (rowData.Processed == 0) {
                var str = rowData.OrderNo;
                var bool = str.indexOf("QD")!=-1;
                if (bool > 0) {
                    if (rowData.RechargeType == 31) {
                        arr.push('<a class="red" href="javascript:void(0)" onclick="OrderRefuseEx(\'' + rowData.OrderNo + '\',\'' + rowData.GameID + '\',' + rowData.Coin + ',' + rowData.RechargeType + ')">拒绝处理</a>');
                        arr.push('<a class="blue" href="javascript:void(0)" onclick="OrderProcess(\'' + rowData.OrderNo + '\',\'' + rowData.GameID + '\',' + rowData.Coin + ',' + rowData.RechargeType + ')">确认处理</a>');
                        arr.push('<a class="red" href="javascript:void(0)" onclick="OrderRefuseDelCoins(\'' + rowData.OrderNo + '\',\'' + rowData.GameID + '\',' + rowData.Coin + ',' + rowData.RechargeType + ')">拒绝并扣币</a>');
                    } else {
                        arr.push('<a class="red" href="javascript:void(0)" onclick="OrderRefuse(\'' + rowData.OrderNo + '\',\'' + rowData.GameID + '\',' + rowData.Coin + ',' + rowData.RechargeType + ')">拒绝处理</a>');
                        arr.push('<a class="blue" href="javascript:void(0)" onclick="ConfirmReCharge(\'' + rowData.OrderNo + '\',\'' + rowData.GameID + '\',' + rowData.Coin + ',' + rowData.RechargeType + ')">确认处理</a>');
                    }
                } else {
                    arr.push(fmtOperator(rowData));
                }
            } else {
                arr.push(fmtOperator(rowData));
            }
            return arr.join(arr.length > 1 ? ' | ' : '');
        }
        function fmtOperator(rowData) {
            if (rowData.Operator) {
                return '操作人：' + rowData.Operator;
            }
            return ' ';
        }
        function fmtRechargeType(value, rowData, rowIndex) {
            if (value == 1)
                return '微信';
            else if (value == 2)
                return '支付宝';
            else if (value == 20)
                return '后台充值';
            else if (value == 21)
                return '后台兑换';
            else if (value == 22)
                return '后台赠送';
            else if (value == 23)
                return '后台扣币';
            else if (value == 30)
                return '前端充值';
            else if (value == 31)
                return '前端提现';
            else
                return '';
        }
        function fmtCoins(value, rowData, rowIndex) {
            return top.goldFormat(value);
    }



        
    function OrderProcess(orderNo, id, coin, RechargeType) {
        confirm('确认处理账号【' + id + '】的兑换？', function () {
            request('/Game/Recharge/OrderProcess', { OrderNo: orderNo }, function (data) {
                //提示消息
                showMsg(data);
                if (data && data.code == 1) {
                    queryData();//重新绑定表格数据
                }
            });
        });
    }

    function OrderRefuse(orderNo, id, coin, RechargeType) {
        confirm('确认拒绝处理账号【' + id + '】的充值？', function () {
            request('/Game/Recharge/OrderRefuse', { OrderNo: orderNo }, function (data) {
                //提示消息
                showMsg(data);
                if (data && data.code == 1) {
                    queryData();//重新绑定表格数据
                }
            });
        });
    }

    function OrderRefuseEx(orderNo, id, coin, RechargeType) {
        confirm('确认拒绝处理账号【' + id + '】的提现，并返还金币？', function () {
            request('/Game/Recharge/OrderRefuseEx', { OrderNo: orderNo }, function (data) {
                //提示消息
                showMsg(data);
                if (data && data.code == 1) {
                    queryData();//重新绑定表格数据
                }
            });
        });
    }

    function ConfirmReCharge(orderNo, id, coin, RechargeType) {
        confirm('确认给账号【' + id + '】充值'  + coin + '？', function () {
            $.ajax({
                url: '/Game/Recharge/ConfirmReCharge',
                data: { OrderNo: orderNo },
                type: 'POST',
                dataType: 'json',
                beforeSend: function () {
                    if ($('.main-loading').length < 1) {
                        $('<div class="main-loading bg"><div class="main-loading-mask">正在处理，请稍待。。。</div></div>').prependTo('.main');
                    }
                },
                success: function (data) {
                    //提示消息
                    showMsg(data);
                    if (data && data.code == 1) {
                        $('#tb_ReChargeRecords').datagrid('reload');
                        queryData();
                    }
                },
                complete: function () {
                    //隐藏Loding
                    hideLoading();
                    queryData();
                }
            });
        });
    }
   
    function OrderRefuseDelCoins(orderNo, id, coin, RechargeType) {
        confirm('确认拒绝处理账号【' + id + '】兑换并扣币？', function () {
            request('/Game/Recharge/OrderRefuseDelCoins', { OrderNo: orderNo }, function (data) {
                //提示消息
                showMsg(data);
                if (data && data.code == 1) {
                    queryData();//重新绑定表格数据
                }
            });
        });
    }

    function clearRecords() {
        $.messager.confirm('确认', '确定要清空全部充值记录吗？此操作不可恢复！', function (r) {
            if (!r) return;
            $.post('/Game/Recharge/ClearRecords', {}, function (res) {
                if (res.code === 1) {
                    $.messager.alert('提示', res.msg, 'info', function () {
                        queryData();
                    });
                } else {
                    $.messager.alert('提示', res.msg, 'error');
                }
            });
        });
    }
       
</script>
}
@*查询条件*@
<form id="frm_srch">
    <table width="100%" border="0" cellpadding="0" cellspacing="0" class="titleQueBg" style="height:40px;">
        <tr>
            <td>
                <div class="left Lpd5">
                    用户账号
                    <input type="text" class="easyui-textbox" name="ID" />
                </div>
                <div class="left Lpd5">
                    所属代理
                    <input type="text" class="easyui-textbox" name="Agency" />
                </div>
                <div class="left Lpd5">
                    订单编号
                    <input type="text" class="easyui-textbox" name="OrderNo" />
                </div>
                <div class="left Lpd5">
                    (收款)支付宝/微信号
                    <input type="text" class="easyui-textbox" name="PayNo" />
                </div>
                <div class="left Lpd5">
                    处理状态
                    <select class="easyui-combobox" name="Processed" data-options="editable:false,panelHeight:130" style="width:155px;">
                        <option value="-1" selected="selected">--全部--</option>
                        <option value="0">未处理</option>
                        <option value="1">已处理</option>
                    </select>
                </div>
                <div class="left Lpd5">
                    开始时间
                    <input class="easyui-datetimebox" data-options="onShowPanel:function(){ $(this).datetimebox('spinner').timespinner('setValue','00:00:00'); }" name="srch_StartTime" id="srch_StartTime"
                           style="width:150px">
                </div>
                <div class="left Lpd5">
                    结束时间
                    <input class="easyui-datetimebox" data-options="onShowPanel:function(){ $(this).datetimebox('spinner').timespinner('setValue','23:59:59'); }" name="srch_EndTime" id="srch_EndTime"
                           style="width:150px">
                </div>
                <div class="left Lmg10">
                    <a href="javascript:void(0);" class="easyui-linkbutton" onclick="queryData();" data-options="plain:true,iconCls:'icon-search'">查找</a>
                </div>
                @if (loginUser != null)
                {
                <div class="left Lmg10">
                    <a href="javascript:void(0);" class="easyui-linkbutton" onclick="clearRecords();" data-options="plain:true,iconCls:'icon-remove'">清理记录</a>
                </div>
                }
            </td>
        </tr>
    </table>
</form>

@*点杀记录信息*@
<table id="tb_ReChargeRecords">
    <thead>
        <tr>
            <th field="RechargeType" width="200" formatter="fmtRechargeType">充值类型</th>
            <th field="OrderNo" width="240" hidden="true">订单编号</th>
            <th field="PayNo" width="200" hidden="true">(收款)支付宝/微信号</th>
            <th field="GameID" width="200">用户账号</th>
            <th field="Agency" width="200">所属代理</th>
            <th field="Coin" width="85" formatter="fmtCoins">充值数量</th>
            <th field="BEF_COINS" width="95" formatter="fmtCoins">充值前金币</th>
            <th field="AFT_COINS" width="95" formatter="fmtCoins">充值后金币</th>
            <th field="CreateTimeStr" width="135">充值时间</th>
            <th field="Processed" width="110" formatter="fmtProcessed">处理状态</th>
            <th field="CreateTime" width="230" formatter="fmtOpt">操作</th>
        </tr>
       
    </thead>

</table>
